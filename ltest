    cleanup
}

testTimeBtime() {
    setup
    touch file
    l --time=btime --show-time -1 > /dev/null
    check "$?" = "0"
    cleanup
}

testTimeBirth() {
    setup
    touch file
    l --time=birth --show-time -1 > /dev/null
    check "$?" = "0"
    cleanup
