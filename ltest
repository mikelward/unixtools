    cleanup
}

testStandaloneBtime() {
    setup
    touch file
    l --btime --show-time -1 > /dev/null
    check "$?" = "0"
    cleanup
}

testStandaloneCtime() {
    setup
    touch file
    l --ctime --show-time -1 > /dev/null
    check "$?" = "0"
    cleanup
}

testStandaloneMtime() {
    setup
    touch file
    l --mtime --show-time -1 > /dev/null
    check "$?" = "0"
    cleanup
}

testSortByBtime() {
    setup
    touch old
    sleep 1
    touch new
    result="$(l --sort=time --time=btime -1)"
    first="$(echo "$result" | head -1)"
    check "$first" = "new"
    cleanup
}

testFormatLong() {
    setup
    touch file
    result="$(l --format=long file)"
    # long format includes modes like rw
    check "$result" != "${result/rw/}"
    cleanup
}

testFormatSingleColumn() {
    setup
    touch a b
    check "$(l --format=single-column)" = "a
b"
    cleanup
}

testFormatVertical() {
    setup
    touch a
    l --format=vertical > /dev/null
    check "$?" = "0"
    cleanup
}

testFormatAcross() {
    setup
    touch a
    l --format=across > /dev/null
    check "$?" = "0"
    cleanup
}

testLongOptionIso() {
    setup
    touch file
    result="$(l --iso --show-time -1 file)"
    # ISO format should match YYYY-MM-DD HH:MM:SS
    check "$result" != "${result/[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]/}"
    cleanup
}

testTimeStyleIso() {
    setup
