testLongOptionBytes() {
    setup
    dd if=/dev/zero of=bigfile bs=1024 count=1 2>/dev/null
    result="$(l --bytes -1 bigfile)"
    # bytes field should show a number
    check "$result" != "${result/1024/}"
    cleanup
}

testLongOptionSize() {
    setup
    touch file
    result="$(l --size -1 file)"
    # size field should show a number before the filename
    check "$result" != "${result/file/}"
    cleanup
}

testLongOptionLinkCount() {
    setup
    touch file
    result="$(l --link-count -1 file)"
    # link count should be at least 1
    check "$result" != "${result/1/}"
    cleanup
}

testLongOptionOwner() {
    setup
    touch file
    result="$(l --owner -1 file)"
    # owner field should be present (non-empty result)
    check "$result" != "${result/file/}"
    cleanup
